__pycache__/
*.pyc
.env
.venv/
dist/
*.egg-info/
# Audit outputs / corpora / brand assets under clients/<slug>/ are
# operator-private; only the client.yaml onboarding contract is tracked
# (per Content Engine v1 U2). Ignore contents of each client dir but
# leave the dirs themselves discoverable so the client.yaml negation can
# fire.
clients/*/**
!clients/.gitkeep
!clients/*/client.yaml

# Voice persona corpora are operator-private (consent-gated for
# regulated personas per Content Engine v1 §Compliance Posture
# parallel-track risk #1). Persona YAMLs (the schema-validated tone
# definitions) are tracked; per-corpus content under
# voice_personas/corpora/<persona>/ is ignored except for .gitkeep
# placeholders that preserve directory existence so load_persona's
# corpus_path existence check passes pre-consent.
#
# Exception: the `jr` persona corpus IS the gofreddy/JR voice substrate
# (formerly autoresearch/archive/v007-curated/programs/references/voice.md
# — pre-U11). It is public-shipped content, not consent-gated, so its
# corpus is tracked end-to-end.
voice_personas/corpora/*/**
!voice_personas/corpora/*/.gitkeep
!voice_personas/corpora/jr/**
.DS_Store
portal/output/
cost_log.jsonl

# Autoresearch — variant runtime data (ported from freddy/.gitignore:124-132)
autoresearch/archive/v*/sessions/
autoresearch/archive/v*/archived_sessions/
autoresearch/archive/v*/logs/
autoresearch/archive/v*/meta-session.log
autoresearch/archive/v*/.session_ids.json
autoresearch/archive/failures.log
autoresearch/archive/current_runtime/
autoresearch/archive/core/
autoresearch/archive/workflows/
autoresearch/adhoc_scores.jsonl
autoresearch/archive/lineage.jsonl

# Harness and playwright runtime artifacts (not source)
harness/runs/
.playwright-cli/

# Claude Code session runtime state (scheduled-task lock, etc.)
.claude/
.worktrees/
