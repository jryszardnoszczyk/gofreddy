# ─── Autoresearch CLI auth (ported from freddy — Phase 7 of migration) ──────
# FREDDY_API_KEY: value from api_keys table; CLI sends as X-API-Key on every
#   backend request. Generate via `INSERT INTO api_keys ... RETURNING key`.
# FREDDY_API_BASE_URL: where the CLI points. Local dev = 8000 uvicorn.
FREDDY_API_KEY=
FREDDY_API_BASE_URL=http://127.0.0.1:8000

# ─── Portal + Auth (required when running the FastAPI app) ──────────────────
# Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
# Dashboard → Settings → Database → Connection string (pooler URI for apps)
DATABASE_URL=
# Filesystem path the API reads per-client JSONL from (Fly volume in prod)
GOFREDDY_CLIENTS_DIR=./clients
