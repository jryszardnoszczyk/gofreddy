# Frontend environment template for local development.

# Supabase local auth endpoint and anon key (from `supabase status`).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<from supabase status>

# Proxy-first default: keep empty/relative in local dev.
# When empty, Vite proxy forwards /v1, /health and /webhooks to backend.
VITE_API_URL=

# ADK v2 streaming endpoint (requires /v2/agent/chat/stream backend)
# VITE_AGENT_V2=1

# Test-only guard for Playwright critical-path e2e lane.
# Must remain disabled outside CI test runs.
VITE_E2E_BYPASS_AUTH=0
