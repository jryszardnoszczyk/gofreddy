{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:spec": "uv run python ../scripts/export_openapi.py",
    "api:generate": "npm run api:spec && openapi-ts -i src/lib/generated/openapi.json -o src/lib/generated && npm run api:spec",
    "api:check": "npm run api:generate && node scripts/check-generated-clean.mjs",
    "contract:guard": "node scripts/contract-guard.mjs",
    "test:contracts": "node --test scripts/*.test.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e:critical": "playwright test -c playwright.critical.config.ts",
    "test:e2e:critical:ci": "playwright test -c playwright.critical.config.ts --reporter=line",
    "contract:check": "npm run api:check && npm run contract:guard && npm run test:contracts && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.92.4",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-sort": "^1.8.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0"
  }
}
