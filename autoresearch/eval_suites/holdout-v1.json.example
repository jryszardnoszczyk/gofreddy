{
  "is_redacted_example": true,
  "suite_id": "holdout-v1",
  "version": "1.0",
  "description": "REDACTED EXAMPLE — shape reference only. The real holdout manifest lives out-of-repo at ~/.config/gofreddy/holdouts/holdout-v1.json (chmod 600). Loaders refuse any manifest with is_redacted_example=true.",
  "eval_target": {
    "backend": "codex",
    "model": "gpt-5.4",
    "reasoning_effort": "high"
  },
  "domains": {
    "geo": [
      {
        "fixture_id": "holdout-geo-example-1",
        "client": "REDACTED",
        "context": "https://REDACTED.example/page-1",
        "version": "1.0",
        "max_iter": 15,
        "timeout": 1200,
        "anchor": true,
        "env": {}
      },
      {
        "fixture_id": "holdout-geo-example-2",
        "client": "REDACTED",
        "context": "https://REDACTED.example/page-2",
        "version": "1.0",
        "max_iter": 15,
        "timeout": 1200,
        "anchor": false,
        "env": {}
      }
    ],
    "competitive": [
      {
        "fixture_id": "holdout-comp-example-1",
        "client": "REDACTED",
        "context": "REDACTED-client-slug",
        "version": "1.0",
        "max_iter": 15,
        "timeout": 1200,
        "anchor": true,
        "env": {}
      }
    ],
    "monitoring": [
      {
        "fixture_id": "holdout-monitoring-example-1",
        "client": "REDACTED",
        "context": "${AUTORESEARCH_HOLDOUT_MONITORING_EXAMPLE_CONTEXT}",
        "version": "1.0",
        "max_iter": 20,
        "timeout": 1200,
        "anchor": true,
        "env": {
          "AUTORESEARCH_WEEK_RELATIVE": "most_recent_complete"
        }
      }
    ],
    "storyboard": [
      {
        "fixture_id": "holdout-storyboard-example-1",
        "client": "REDACTED",
        "context": "youtube",
        "version": "1.0",
        "max_iter": 30,
        "timeout": 1800,
        "anchor": true,
        "env": {}
      }
    ],
    "marketing_audit": [
      {
        "fixture_id": "holdout-marketing-audit-example-1",
        "client": "REDACTED",
        "context": "https://REDACTED.example",
        "version": "1.0",
        "max_iter": 50,
        "timeout": 4200,
        "anchor": true,
        "env": {
          "_comment": "Marketing-audit fixtures populate after first 3 paid audits ship. Each fixture is a (prospect_url, expected-deliverable-shape, ground-truth-rubric-scores) triple. context = test-prospect-url; loader synthesizes a fresh audit run, scores it against MA-1..MA-8 judges, compares against the anchor variant. anchor=true means this fixture defines the comparison baseline for variant rotation."
        }
      }
    ]
  }
}
